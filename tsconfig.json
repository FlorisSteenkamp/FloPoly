{
    "compilerOptions": {
        "strict": true,
        "module": "esnext",
        "target": "esnext",
        "declaration": true,
        "noEmitOnError": true,
        "sourceMap": true,
        "rootDir": "./src",
        "outDir": "./node",
        "moduleResolution": "bundler",
        "types": ["node"]
    },
    "include": [
        "src/index.ts",
        "src/**/*.d.ts"
    ],
    "exclude": [
        "node_modules"
    ]
}